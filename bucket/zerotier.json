{
    "homepage": "https://www.zerotier.com",
    "version": "1.16.2",
    "description": "ZeroTier is a smart programmable Ethernet switch for planet Earth",
    "url": "https://download.zerotier.com/RELEASES/1.16.2/dist/ZeroTier%20One.msi#/setup.msi_",
    "hash": "42514072b0fe44b8f66e0395bcd23a0b1d1642c28ed00831f1527b2f41b14670",
    "installer": {
        "script": "Start-Process -Wait msiexec \"/i `\"$dir\\setup.msi_`\" /qn INSTALLFOLDER=`\"$dir`\"\" -Verb RunAs"
    },
    "post_install": [
        "$Source = \"$persist_dir\"",
        "$Target = \"$env:LocalAppData\\ZeroTier\"",
        "New-Item -ItemType Directory -Path $Source -ErrorAction Ignore | Out-Null",
        "New-Item -ItemType Junction -Path $Target -Target $Source -ErrorAction Ignore | Out-Null"
    ],
    "pre_uninstall": [
        "$Source = \"$persist_dir\\AppData\"",
        "$Target = \"$env:LocalAppData\\ZeroTier\"",
        "cmd /c rmdir /s /q $Target"
    ],
    "uninstaller": {
        "script": "Start-Process -Wait msiexec \"/x `\"$dir\\setup.msi_`\" /qn\" -Verb RunAs"
    },
    "checkver": {
        "github": "https://github.com/zerotier/ZeroTierOne"
    },
    "autoupdate": {
        "url": "https://download.zerotier.com/RELEASES/$version/dist/ZeroTier%20One.msi#/setup.msi_"
    }
}
